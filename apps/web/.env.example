# FastAPI Trend Engine API (Uvicorn default). Used by the Next.js app for API calls.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: server-only override (falls back to NEXT_PUBLIC_API_URL then localhost)
# API_URL=http://localhost:8000

# Stripe (server-side only)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_CREATOR_PRICE_ID=price_xxx
# STRIPE_PRO_PRICE_ID=price_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Public site URL for Stripe checkout redirects
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase server role for trusted backend writes (webhooks/admin jobs)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Weekly trend digest cron — set CRON_SECRET in Vercel; cron calls GET /api/cron/trend-digest with Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=

# Optional: require this header on FastAPI POST /trend-ideas/digest-topics (same value in the API server env)
# TREND_DIGEST_KEY=

# Gmail SMTP (idea feedback + weekly digest). Use an App Password for the sending account.
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# Resend email delivery for idea feedback notifications
# RESEND_API_KEY=re_xxx
# FEEDBACK_ADMIN_EMAIL=corbanweaver5@gmail.com
# FEEDBACK_SENDER_EMAIL=onboarding@resend.dev
