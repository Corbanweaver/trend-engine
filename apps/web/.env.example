# FastAPI Content Engine (Uvicorn default). Used by the Next.js app for API calls.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: server-only override (falls back to NEXT_PUBLIC_API_URL then localhost)
# API_URL=http://localhost:8000

# Stripe (server-side only)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_CREATOR_PRICE_ID=price_xxx
# STRIPE_PRO_PRICE_ID=price_xxx

# Public site URL for Stripe checkout redirects
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
