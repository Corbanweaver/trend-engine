# FastAPI Trend Engine API (Uvicorn default). Used by the Next.js app for API calls.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: server-only override (falls back to NEXT_PUBLIC_API_URL then localhost)
# API_URL=http://localhost:8000

# Supabase
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin and support
# ADMIN_EMAILS=you@example.com,other-admin@example.com
# NEXT_PUBLIC_SUPPORT_EMAIL=support@contentideamaker.com

# OpenAI. Use this for Next.js assistant chat and FastAPI image generation when not using Replit AI integrations.
# OPENAI_API_KEY=sk-proj_xxx
# OPENAI_CHAT_MODEL=gpt-5.2
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1024
# OPENAI_IMAGE_QUALITY=low
# OPENAI_IDEA_IMAGE_FORMAT=webp

# Stripe (server-side only)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_CREATOR_PRICE_ID=price_xxx
# STRIPE_PRO_PRICE_ID=price_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Public site URL for Stripe checkout redirects
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Health checks
# HEALTHCHECK_SECRET=

# Weekly trend digest cron — set CRON_SECRET in Vercel; cron calls GET /api/cron/trend-digest with Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=

# Optional: require this header on FastAPI POST /trend-ideas/digest-topics (same value in the API server env)
# TREND_DIGEST_KEY=

# Optional but recommended before launch: set the same random secret in the web app and Railway FastAPI service.
# When OPERATIONAL_API_KEY is present on FastAPI, /trend-ideas routes require X-Operational-Key.
# TREND_ENGINE_BACKEND_KEY=
# OPERATIONAL_API_KEY=

# OpenAI spend guardrails (credit units across AI endpoints). Set 0 to disable.
# OPENAI_COST_BUDGET=0
# OPENAI_COST_BUDGET_WINDOW_SECONDS=86400

# Platform source integrations for the FastAPI backend
# YOUTUBE_API_KEY=
# APIFY_API_TOKEN=
# APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-scraper

# Optional backend protections
# MAX_REQUEST_BODY_BYTES=262144
# EXPENSIVE_ENDPOINT_RATE_LIMIT=20
# EXPENSIVE_ENDPOINT_RATE_WINDOW_SECONDS=60

# Resend email delivery for idea feedback notifications.
# If you verified auth.contentideamaker.com, a sender like no-reply@auth.contentideamaker.com is valid.
# RESEND_API_KEY=re_xxx
# FEEDBACK_ADMIN_EMAIL=corbanweaver5@gmail.com
# FEEDBACK_SENDER_EMAIL=no-reply@auth.contentideamaker.com

# Gmail SMTP fallback (idea feedback + weekly digest). Use an App Password for the sending account.
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
